{
    "sampling": {
        "timestep":         5e-4,
        "logging_interval": 100000,
        "phases": [
            {"name": "relaxation", "steps": 5000000, "sampling_interval": 10000},
            {"name": "production", "steps": 1000000, "sampling_interval":   100}
        ],
        "random_seed":      0,
        "output_filename":  "_output.h5"
    },

    "initialization": {
        "extruder_preloading":   true,
        "initial_step_monomers": 10,
        "initial_step_scale":    0.1
    },

    "chain": {
        "repulsive_distance": 1,
        "repulsive_energy":   20,
        "spring_length":      1,
        "spring_constant":    200,
        "monomer_mobility":   3.0
    },

    "association": {
        "valency":              3,
        "association_distance": 1.5,
        "association_energy":   5,
        "association_rate":     1,
        "dissociation_rate":    0.1
    },

    "extruder": {
        "loading_rate":       1e-5,
        "unloading_rate":     1e-3,
        "extrusion_rate":     3,
        "contraction_rate":   3,
        "crossing_factor":    1,
        "spring_length":      1,
        "spring_constant":    200
    },

    "chains": [
        {
            "length": 400,

            "association_features": [
                {"site": {"start": 15, "end": 17}, "valency": 0}, {"site": {"start": 49, "end": 53}, "valency": 0}, {"site": 55, "valency": 0}, {"site": 65, "valency": 0}, {"site": {"start": 76, "end": 79}, "valency": 0}, {"site": 88, "valency": 0}, {"site": {"start": 120, "end": 122}, "valency": 0}, {"site": 124, "valency": 0}, {"site": 152, "valency": 0}, {"site": 167, "valency": 0}, {"site": 173, "valency": 0}, {"site": {"start": 183, "end": 186}, "valency": 0}, {"site": 199, "valency": 0}, {"site": 209, "valency": 0}, {"site": {"start": 230, "end": 233}, "valency": 0}, {"site": {"start": 250, "end": 254}, "valency": 0}, {"site": 267, "valency": 0}, {"site": 333, "valency": 0}, {"site": {"start": 336, "end": 339}, "valency": 0}, {"site": 350, "valency": 0}, {"site": 360, "valency": 0}, {"site": 372, "valency": 0}, {"site": {"start": 398, "end": 400}, "valency": 0},

                {"site": {"start": 197, "end": 204}, "valency": 0}
            ],

            "extruder_features": [
                {"site": {"start":   0, "end":  14}, "loading": 0, "@what": "margin"},
                {"site": {"start": 399, "end": 400}, "loading": 0, "@what": "margin"},

                {"site":  14, "arrival": 0, "loading": 0, "@what": "bounding barrier"},
                {"site":  15, "departure": 0, "@what": "ctcf"},
                {"site": 173, "departure": 0, "@what": "ctcf"},
                {"site": 174, "arrival": 0, "loading": 0, "@what": "bounding barrier"},

                {"site": 209, "arrival": 0, "loading": 0, "@what": "bounding barrier"},
                {"site": 210, "departure": 0, "@what": "ctcf"},
                {"site": 397, "departure": 0, "@what": "ctcf"},
                {"site": 398, "arrival": 0, "loading": 0, "@what": "bounding barrier"}
            ]
        }
    ]
}
