
{
    "sampling": {
        "timestep":         5e-4,
        "logging_interval": 100000,
        "phases": [
            {"name": "relaxation", "steps": 3000000, "sampling_interval": 10000},
            {"name": "production", "steps": 1000000, "sampling_interval":   100}
        ],
        "random_seed":      0,
        "output_filename":  "_output.h5"
    },

    "initialization": {
        "extruder_preloading":   true,
        "initial_step_monomers": 10,
        "initial_step_scale":    0.1
    },

    "chain": {
        "repulsive_distance":  1,
        "repulsive_energy":    20,
        "spring_length":       1,
        "spring_constant":     200,
        "monomer_mobility":    3.0
    },

    "association": {
        "valency":              5,
        "association_distance": 1.5,
        "association_energy":   5,
        "association_rate":     2,
        "dissociation_rate":    0.2
    },

    "extruder": {
        "loading_rate":     0,
        "unloading_rate":   1e-3,
        "extrusion_rate":   1.2,
        "contraction_rate": 1,
        "crossing_factor":  0,
        "spring_length":    1,
        "spring_constant":  200
    },

    "chains": [
        {
            "length": 200,

            "association_features": [
            ],

            "extruder_features": [
                {"site": {"start":   0, "end":   5}, "loading": 0},
                {"site": {"start": 196, "end": 200}, "loading": 0},
                {"site":   5, "loading": 0, "arrival": 0},
                {"site": 195, "loading": 0, "arrival": 0}
            ]
        }
    ]
}
