                {"site": {"start": 15, "end": 17}, "loading": 10}, {"site": {"start": 49, "end": 53}, "loading": 10}, {"site": 55, "loading": 10}, {"site": 65, "loading": 10}, {"site": {"start": 76, "end": 79}, "loading": 10}, {"site": 88, "loading": 10}, {"site": {"start": 120, "end": 122}, "loading": 10}, {"site": 124, "loading": 10}, {"site": 152, "loading": 10}, {"site": 167, "loading": 10}, {"site": 173, "loading": 10}, {"site": {"start": 183, "end": 186}, "loading": 10}, {"site": 199, "loading": 10}, {"site": 203, "loading": 10}, {"site": {"start": 230, "end": 233}, "loading": 10}, {"site": {"start": 250, "end": 254}, "loading": 10}, {"site": 267, "loading": 10}, {"site": 333, "loading": 10}, {"site": {"start": 336, "end": 339}, "loading": 10}, {"site": 350, "loading": 10}, {"site": 360, "loading": 10}, {"site": 372, "loading": 10}, {"site": {"start": 398, "end": 400}, "loading": 10},

                {"site": {"start": 197, "end": 204}, "loading": 0, "arrival": 0},

