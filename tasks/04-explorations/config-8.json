{
    "sampling": {
        "timestep":         5e-4,
        "logging_interval": 100000,
        "phases": [
            {"name": "relaxation", "steps": 5000000, "sampling_interval": 10000},
            {"name": "production", "steps": 1000000, "sampling_interval":   100}
        ],
        "random_seed":      0,
        "output_filename":  "_output.h5"
    },

    "environment": {
        "temperature": 1
    },

    "initialization": {
        "extruder_preloading":   true,
        "initial_step_monomers": 10,
        "initial_step_scale":    0.1
    },

    "chain": {
        "repulsive_distance":  1,
        "repulsive_energy":    20,
        "spring_length":       1,
        "spring_constant":     200,
        "monomer_mobility":    3.0
    },

    "association": {
        "valency":              3,
        "association_distance": 1.5,
        "association_rate":     10,
        "dissociation_rate":    1,
        "association_energy":   3
    },

    "extruder": {
        "loading_rate":     1e-5,
        "unloading_rate":   1e-3,
        "extrusion_rate":   30.1,
        "contraction_rate": 30.0,
        "crossing_factor":  0,
        "spring_length":    1,
        "spring_constant":  200
    },

    "chains": [{"length": 200}]
}
