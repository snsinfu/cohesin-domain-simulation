{
    "sampling": {
        "timestep":          1e-5,
        "relaxation_steps":  1000000,
        "production_steps":  0,
        "logging_interval":  100000,
        "sampling_interval": 10000,
        "random_seed":       0,
        "output_filename":   "_output.h5"
    },

    "environment": {
        "temperature":               1,
        "container_radius":          10,
        "container_spring_constant": 0
    },

    "initialization": {
        "initial_step_monomers": 10,
        "initial_step_scale":    1
    },

    "chain": {
        "repulsive_distance":  1,
        "repulsive_energy":    50,
        "spring_length":       1,
        "spring_constant":     200,
        "monomer_mobility":    100
    },

    "association": {
        "valency":              4,
        "association_distance": 1.5,
        "association_rate":     1,
        "dissociation_rate":    0.1,
        "association_energy":   5
    },

    "chains": [
        {"length": 100}
    ]
}
