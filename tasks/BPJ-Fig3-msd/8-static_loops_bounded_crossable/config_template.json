{
    "@meta": {
        "config_params": {
            "chain_length":             200,
            "acetylation_level":        0.2,
            "acetylation_size":         2,
            "acetylation_feature":      {"valency": 1},
            "static_loop_count":        5,
            "static_loop_size_min":     30,
            "static_loop_size_max":     "random",
            "static_loop_crossable":    true,
            "gene_count":               2,
            "gene_size":                70,
            "gene_size_min":            30
        },
        "config_seed":                  0,
        "config_count":                 10
    },

    "sampling": {
        "logging_interval":             100000,
        "phases": [
            {"name": "relaxation_pre",  "timestep": 1e-6, "steps":  100000, "sampling_interval": 100000, "spring_factor": 0.1},
            {"name": "relaxation",      "timestep": 1e-4, "steps": 1000000, "sampling_interval": 100000, "spring_factor": 0.1},
            {"name": "relaxation_post", "timestep": 1e-5, "steps":  100000, "sampling_interval": 100000},
            {"name": "production",      "timestep": 1e-5, "steps": 5000000, "sampling_interval":   5000}
        ],
        "random_seed":                  0,
        "output_filename":              "_output.h5"
    },

    "initialization": {
        "preload_cohesin":              false,
        "initial_step_monomers":        10,
        "initial_step_scale":           0.1
    },

    "chain": {
        "repulsive_distance":           1,
        "repulsive_energy":             20,
        "spring_length":                1,
        "spring_constant":              100,
        "monomer_mobility":             200
    },

    "association": {
        "valency":                      3,
        "association_distance":         1.5,
        "association_energy":           5,
        "association_rate":             200,
        "dissociation_rate":            50
    },

    "chains": null
}
