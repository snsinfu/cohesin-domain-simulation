{
    "@meta": {
        "sweep_ranges": {
            "association_valency:int":   [1, 5],
            "association_energy:real":   [0, 5],
            "dissociation_rate:logreal": [20, 200]
        },
        "config_params": {
            "chain_length":             200
        },
        "config_seed":                  0,
        "config_count":                 300
    },

    "sampling": {
        "logging_interval":             100000,
        "phases": [
            {"name": "relaxation", "timestep": 1e-5, "steps": 10000000, "sampling_interval": 100000},
            {"name": "production", "timestep": 1e-5, "steps":  5000000, "sampling_interval":   5000}
        ],
        "random_seed":                  0,
        "output_filename":              "_output.h5"
    },

    "initialization": {
        "initial_step_monomers":        10,
        "initial_step_scale":           0.1
    },

    "chain": {
        "repulsive_distance":           1,
        "repulsive_energy":             20,
        "spring_length":                1,
        "spring_constant":              100,
        "monomer_mobility":             200
    },

    "association": {
        "valency":                      null,
        "association_distance":         1.5,
        "association_energy":           null,
        "association_rate":             200,
        "dissociation_rate":            50
    },

    "chains": null
}
